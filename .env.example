ANTHROPIC_API_KEY=

# Hybrid retrieval (enabled by default; set to off for lexical-only retrieval).
SONNY_HYBRID_RETRIEVAL=on
SONNY_EMBED_MODEL=nomic-embed-text
SONNY_EMBED_URL=http://localhost:11434/api/embed

# OpenAI-compatible backend (free cloud open models: Groq / NVIDIA NIM / OpenRouter).
# Activate with SONNY_BACKEND=openai. Works with any /v1 endpoint that supports tool calling.
SONNY_OPENAI_BASE_URL=https://api.groq.com/openai/v1
SONNY_OPENAI_API_KEY=
